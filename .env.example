# ─── ENVIRONMENT ──────────────────────────────────────────────────────────────
# OPTIONAL | The node environment | Default: development
NODE_ENV=development

# ─── DATABASE ─────────────────────────────────────────────────────────────────
# REQUIRED | PostgreSQL connection string for Drizzle ORM
# Local (Docker): postgresql://postgres:postgres@localhost:5455/db
# Prod (Neon/Vercel): postgresql://user:password@host/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5455/db
# OPTIONAL | The maximum number of connections in the pool | Default: 10
DATABASE_POOL_MAX=10
# OPTIONAL | The maximum time in seconds to keep idle connections | Default: 30
DATABASE_IDLE_TIMEOUT=30
# OPTIONAL | The maximum time in seconds to wait for a connection | Default: 10
DATABASE_CONNECT_TIMEOUT=10

# ─── GLITCHTIP/SENTRY (CRASH REPORTING) ───────────────────────────────────────
# OPTIONAL | GlitchTip/Sentry DSN for server-side error tracking
# GlitchTip is used as a lightweight Sentry alternative in dev/docker.
SENTRY_DSN=http://xxx@localhost:9000/1
NEXT_PUBLIC_SENTRY_DSN=http://xxx@localhost:9000/1
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=app-dev
LOKI_URL=http://localhost:3100

# ─── CACHE ────────────────────────────────────────────────────────────────────
# Local (Docker): redis://localhost:6379
REDIS_URL=redis://localhost:6379
# Prod (Vercel KV): Automatic via Vercel integration
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── MAILER ───────────────────────────────────────────────────────────────────
# Dev  (Mailpit Docker) : smtp://localhost:1025
# Prod (Stalwart VPS)   : smtps://user:password@mail.yourdomain.com:465
SMTP_URL=smtp://localhost:1025
MAIL_FROM="nexaas <noreply@nexaas.dev>"
