{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "ignore": [
    "commitlint.config.mjs",
    "emails/**",
    "postcss.config.mjs",
    "scripts/migrate.mjs",
    "src/core/db/index.ts",
    "src/core/errors/index.ts",
    "src/core/i18n/navigation.ts",
    "src/core/i18n/request.ts",
    "src/core/lib/redis.ts",
    "src/core/lib/request.ts",
    "src/core/mailer/**",
    "src/core/observability/logger.ts",
    "src/core/observability/observability.ts",
    "src/core/types/index.ts",
    "src/domains/newsletter/actions/index.ts",
    "src/domains/newsletter/emails/index.tsx",
    "src/domains/newsletter/errors/index.ts",
    "src/ui/components/ui/**",
    "src/ui/helpers/**"
  ],
  "ignoreBinaries": ["gitleaks"],
  "ignoreDependencies": [
    "@commitlint/config-conventional",
    "@react-email/components",
    "@react-email/preview-server",
    "@react-email/render",
    "@types/nodemailer",
    "cross-env",
    "date-fns",
    "nodemailer",
    "pino-loki",
    "pino-pretty"
  ]
}
