{
  "name": "nexaas",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "description": "A scalable, production-ready SaaS boilerplate built for high performance and rapid prototyping in Next.js 16.",
  "author": {
    "name": "OCLKA",
    "email": "bonjour@oclka.dev",
    "url": "https://oclka.dev"
  },
  "keywords": [
    "nextjs",
    "saas",
    "boilerplate",
    "typescript",
    "tailwindcss",
    "drizzle",
    "auth",
    "stripe",
    "vercel"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "test:e2e:report": "pnpm exec playwright show-report",
    "test:mutate": "stryker run",
    "test:mutate:only": "pnpm exec stryker run --mutate",
    "check:types": "tsc --noEmit",
    "check:secrets": "if command -v gitleaks > /dev/null; then gitleaks protect --staged --verbose; else echo '⚠️ gitleaks is not installed locally. Skipping secret scan.'; fi",
    "check:fast": "pnpm check:types && pnpm lint:fix && true",
    "check:all": "pnpm check:types && pnpm lint:fix && pnpm check:secrets && pnpm audit --audit-level=high && pnpm test:coverage && pnpm build && true",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "knip": "knip",
    "prepare": "husky",
    "release": "changeset version",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "email:dev": "email dev"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "@sentry/nextjs": "^10.48.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@upstash/redis": "^1.37.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "motion": "^12.38.0",
    "next": "16.2.3",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-loki": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "^4.2.0",
    "slugify": "^1.6.9",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@react-email/preview-server": "^5.2.10",
    "@stryker-mutator/api": "^9.6.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "babel-plugin-react-compiler": "1.0.0",
    "commitlint": "^20.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.4.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-email": "^5.2.10",
    "tailwindcss": "^4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "next": "16.2.3",
      "esbuild": "0.25.0"
    }
  }
}
